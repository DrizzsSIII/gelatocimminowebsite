{
  "permissions": {
    "allow": [
      "PowerShell(Get-Process | Where-Object {$_.Name -eq \"node\"} | Select-Object Id, Name)",
      "PowerShell(Stop-Process -Id 2368 -Force)",
      "PowerShell($html = \\(Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing\\).Content; $start = $html.IndexOf\\(\"hours\"\\); $html.Substring\\([Math]::Max\\(0,$start-200\\), 500\\) 2>&1 | Select-Object -First 20)",
      "PowerShell($html = \\(Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing\\).Content; $idx = $html.IndexOf\\(\"color:\"\\); if \\($idx -gt 0\\) { $html.Substring\\([Math]::Max\\(0,$idx-100\\), 300\\) } else { \"No inline style found\" })",
      "PowerShell($html = \\(Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing\\).Content; $idx = $html.IndexOf\\(\"6B6B6B\"\\); if \\($idx -gt 0\\) { $html.Substring\\([Math]::Max\\(0,$idx-100\\), 200\\) } else { \"Not found\" })"
    ]
  }
}
