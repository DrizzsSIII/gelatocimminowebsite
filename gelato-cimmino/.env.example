# Google Places API — get a key at https://console.cloud.google.com
# Enable "Places API (New)" for your project
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Place ID for Gelato Cimmino
# Find it at: https://developers.google.com/maps/documentation/places/web-service/place-id
# Search for "Gelato Cimmino 7140 E Main St Scottsdale AZ"
GELATO_PLACE_ID=your_place_id_here
